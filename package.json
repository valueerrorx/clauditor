{
  "name": "clauditor",
  "version": "0.2.3",
  "description": "clauditor (Claude + audit): records mic + system audio, transcribes offline with whisper.cpp and summarizes with Claude into linked markdown protocols.",
  "type": "module",
  "main": "./out/main/index.js",
  "author": "Thomas Weissel <valueerror@gmail.com>",
  "license": "GPL-3.0-or-later",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "model": "nodejs-whisper download",
    "compile": "electron-vite build",
    "build": "electron-vite build && electron-builder",
    "build:mac:arm64": "electron-vite build && electron-builder --mac --arm64"
  },
  "dependencies": {
    "marked": "^18.0.5",
    "nodejs-whisper": "^0.2.9"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "electron": "^33.2.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^2.3.0",
    "vite": "^5.4.11",
    "vue": "^3.5.13"
  }
}
